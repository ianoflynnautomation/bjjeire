:{$PORT:80} {
	root * /srv
	encode zstd gzip

	header {
		X-Frame-Options SAMEORIGIN
		X-Content-Type-Options nosniff
		-Server
	}

	@assets {
		path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.wasm
	}
	header @assets Cache-Control "public, max-age=31536000, immutable"

	handle /health {
		respond "OK" 200
	}

	# Proxy /api/* to the backend — used in docker-compose.
	# In Kubernetes, HTTPRoute intercepts /api/* at the gateway so this block is never reached.
	handle /api/* {
		reverse_proxy {$SERVICES_API_HTTP_0:http://api:80}
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}

{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "CorsOptions": {
        "AllowedOrigins": [
            "*"
        ]
    },
    "ConnectionStrings": {
        "Mongodb": "mongodb://localhost:27017",
        "Litedb": ""
    },
    "DatabaseOptions": {
        "UseLiteDb": false
    },
    "RateLimitOptions": {
        "EnableRateLimiting": false,
        "PermitLimit": 5,
        "WindowInSeconds": 10,
        "RejectionStatusCode": 429
    },
    "CacheOptions": {
        "DefaultExpirationMinutes": 5
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.ApplicationInsights",
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.CorrelationId",
            "Serilog.Enrichers.Thread"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System.Net.Http.HttpClient": "Warning",
                "BjjWorld.Api": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "ApplicationInsights",
                "Args": {
                    "connectionString": "${APPLICATIONINSIGHTS_CONNECTION_STRING}",
                    "telemetryConverter": "Serilog.Sinks.ApplicationInsights.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithCorrelationId",
            "WithMachineName",
            "WithThreadId",
            "WithEnvironmentUserName"
        ],
        "Filter": [
            {
                "Name": "ByExcluding",
                "Args": {
                    "expression": "SourceContext = 'Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware'"
                }
            }
        ],
        "Destructure": [
            {
                "Name": "ToMaximumStringLength",
                "Args": {
                    "maximumStringLength": 4096
                }
            }
        ],
        "Properties": {
            "Application": "${OTEL_SERVICE_NAME:-BjjWorld.Api}",
            "Environment": "Production"
        }
    },
    "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
    "OTEL_RESOURCE_ATTRIBUTES": {
        "service.name": "${OTEL_SERVICE_NAME:-apiservice}",
        "deployment.environment": "Production"
    },
    "SecurityHeaderOptions": {
        "Enable": true,
        "Headers": {
            "XContentTypeOptions": "nosniff",
            "ReferrerPolicy": "no-referrer",
            "XXSSProtection": "1; mode=block",
            "XFrameOptions": "DENY",
            "ContentSecurityPolicy": "block-all-mixed-content; style-src 'self' 'unsafe-inline'; font-src 'self'; form-action 'self'; frame-ancestors 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'",
            "PermissionsPolicy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
            "StrictTransportSecurity": "max-age=31536000"
        }
    }
}
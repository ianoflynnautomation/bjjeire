{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "CorsOptions": {
        "AllowedOrigins": [
            "*"
        ]
    },
    "ConnectionStrings": {
        "Mongodb": "mongodb://localhost:27017",
        "Litedb": ""
    },
    "DatabaseOptions": {
        "UseLiteDb": false
    },
    "RateLimitOptions": {
        "EnableRateLimiting": false,
        "PermitLimit": 5,
        "WindowInSeconds": 10,
        "RejectionStatusCode": 429
    },
    "CacheOptions": {
        "DefaultExpirationMinutes": 5
    },
    "Serilog": {
        "Using": [
            "Serilog.Sinks.Console",
            "Serilog.Sinks.OpenTelemetry",
            "Serilog.Enrichers.Environment",
            "Serilog.Enrichers.CorrelationId",
            "Serilog.Enrichers.Thread"
        ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System.Net.Http.HttpClient": "Warning",
                "BjjWorld.Api": "Information"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "OpenTelemetry",
                "Args": {
                    "endpoint": "${GRAFANA_OTLP_ENDPOINT}",
                    "protocol": "HttpProtobuf",
                    "headers": {
                        "Authorization": "${GRAFANA_OTLP_AUTH_HEADER}"
                    },
                    "resourceAttributes": {}
                }
            }
        ],
        "Enrich": [
            "FromLogContext",
            "WithCorrelationId",
            "WithMachineName",
            "WithThreadId",
            "WithEnvironmentUserName"
        ],
        "Filter": [
            {
                "Name": "ByExcluding",
                "Args": {
                    "expression": "SourceContext = 'Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware'"
                }
            }
        ],
        "Destructure": [
            {
                "Name": "ToMaximumStringLength",
                "Args": {
                    "maximumStringLength": 4096
                }
            }
        ],
        "Properties": {
            "Application": "${OTEL_SERVICE_NAME:-BjjWorld.Api}",
            "Environment": "Production"
        }
    },
    "OTEL_EXPORTER_OTLP_ENDPOINT": "${GRAFANA_OTLP_ENDPOINT}",
    "OTEL_EXPORTER_OTLP_HEADERS": "Authorization=${GRAFANA_OTLP_AUTH_HEADER}",
    "OTEL_RESOURCE_ATTRIBUTES": {
        "service.name": "${OTEL_SERVICE_NAME:-apiservice}",
        "deployment.environment": "Production"
    }
}
{
  "CorsOptions": {
    "AllowedOrigins": [
      "*"
    ]
  },
  "ConnectionStrings": {
    "Mongodb": "mongodb://localhost:27017",
    "Litedb": ""
  },
  "DatabaseOptions": {
    "UseLiteDb": false
  },
  "RateLimitOptions": {
    "EnableRateLimiting": false,
    "PermitLimit": 5,
    "WindowInSeconds": 10,
    "RejectionStatusCode": 429
  },
  "CacheOptions": {
    "DefaultExpirationMinutes": 5
  },
  "JwtOptions": {
    "Issuer": "your-app-issuer",
    "Audience": "your-app-audience",
    "Key": "REPLACE_THIS_WITH_A_VERY_STRONG_AND_LONG_SECRET_KEY_FOR_PRODUCTION_MIN_32_CHARS"
  },
  "ApiKeyOptions": {
    "HeaderName": "X-API-KEY",
    "ApiKeyValue": "REPLACE_THIS_WITH_YOUR_ACTUAL_SECRET_API_KEY_FOR_PRODUCTION"
  },
  "AdminCredentials": {
    "Username": "admin_user_prod",
    "Password": "REPLACE_THIS_WITH_A_VERY_STRONG_PASSWORD_FOR_ADMIN_TOKEN_GENERATION_IN_PRODUCTION"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Sinks.OpenTelemetry",
      "Serilog.Enrichers.CorrelationId",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "BjjWorld.Api": "Information",
        "MongoDB.Driver.Core.Connection": "Information",
        "MongoDB.Driver.Core.Events": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "restrictedToMinimumLevel": "Warning"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "${SEQ_URL}",
          "restrictedToMinimumLevel": "Information",
          "bufferBaseFilename": "./logs/buffer/seq",
          "batchPostingLimit": 100,
          "period": "0.0.0.0:0:2"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
          "protocol": "HttpProtobuf",
          "restrictedToMinimumLevel": "Information",
          "resourceAttributes": {
            "service.name": "BjjWorld.Api",
            "deployment.environment": "production"
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithCorrelationId",
      "WithMachineName",
      "WithThreadId",
      "WithSpanId",
      "WithTraceId"
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware' and @Level = 'Error'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Serilog.Sinks.OpenTelemetry.OpenTelemetrySink' and @Level = 'Debug'"
        }
      }
    ],
    "Destructure": [
      {
        "Name": "ToMaximumStringLength",
        "Args": {
          "maximumStringLength": 4096
        }
      },
      {
        "Name": "ToMaximumDepth",
        "Args": {
          "maximumDepth": 10
        }
      }
    ],
    "Properties": {
      "Application": "BjjWorld.Api",
      "ServiceVersion": "1.0.0"
    }
  },
  "SecurityHeaderOptions": {
    "Enable": true,
    "Headers": {
      "XContentTypeOptions": "nosniff",
      "ReferrerPolicy": "no-referrer",
      "XXSSProtection": "1; mode=block",
      "XFrameOptions": "DENY",
      "ContentSecurityPolicy": "block-all-mixed-content; style-src 'self' 'unsafe-inline'; font-src 'self'; form-action 'self'; frame-ancestors 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'",
      "PermissionsPolicy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
      "StrictTransportSecurity": "max-age=31536000"
    }
  }
}

{
  "CorsOptions": {
    "AllowedOrigins": [
      "https://api:443",
      ""
    ]
  },
  "ConnectionStrings": {
    "Mongodb": "mongodb://localhost:27017",
    "Litedb": ""
  },
  "DatabaseOptions": {
    "UseLiteDb": false
  },
  "RateLimitOptions": {
    "EnableRateLimiting": false,
    "PermitLimit": 5,
    "WindowInSeconds": 10,
    "RejectionStatusCode": 429
  },
  "CacheOptions": {
    "DefaultExpirationMinutes": 5
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_DEV_TENANT_ID",
    "ClientId": "YOUR_DEV_CLIENT_ID",
    "Audience": "api://YOUR_DEV_CLIENT_ID"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Debug",
      "Serilog.Sinks.OpenTelemetry",
      "Serilog.Enrichers.CorrelationId",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Routing": "Information",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Information",
        "System.Net.Http.HttpClient": "Information",
        "BjjWorld.Api": "Debug",
        "MongoDB.Driver.Core.Connection": "Information",
        "MongoDB.Driver.Core.Events": "Information" 
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3} ({SourceContext:l})] {Message:lj}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "Debug",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3} ({SourceContext:l})] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
          "protocol": "HttpProtobuf",
          "restrictedToMinimumLevel": "Information",
          "resourceAttributes": {
            "service.name": "BjjWorld.Api",
            "deployment.environment": "development"
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithCorrelationId",
      "WithMachineName",
      "WithThreadId",
      "WithSpanId",
      "WithTraceId"
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware' and @Level = 'Error'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Serilog.Sinks.OpenTelemetry.OpenTelemetrySink' and @Level = 'Debug'"
        }
      }
    ],
    "Destructure": [
      {
        "Name": "ToMaximumStringLength",
        "Args": {
          "maximumStringLength": 1000
        }
      },
      {
        "Name": "ToMaximumDepth",
        "Args": {
          "maximumDepth": 10
        }
      }
    ],
    "Properties": {
      "Application": "BjjWorld.Api",
      "ServiceVersion": "1.0.0-dev"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
  "OTEL_RESOURCE_ATTRIBUTES": {
    "service.name": "BjjWorld.Api",
    "deployment.environment": "development"
  }
}

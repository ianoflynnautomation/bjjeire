{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "CorsOptions": {
    "AllowedOrigins": [
      "https://api:443",
      ""
    ]
  },
  "ConnectionStrings": {
    "Mongodb": "mongodb://localhost:27017",
    "Litedb": ""
  },
  "DatabaseOptions": {
    "UseLiteDb": false
  },
  "RateLimitOptions": {
    "EnableRateLimiting": true,
    "PermitLimit": 5,
    "WindowInSeconds": 10,
    "RejectionStatusCode": 429
  },
  "CacheOptions": {
    "DefaultExpirationMinutes": 5
  },
  "JwtOptions": {
    "Issuer": "your-dev-issuer",
    "Audience": "your-dev-audience",
    "Key": "THIS_IS_A_DEV_JWT_SECRET_KEY_THAT_IS_AT_LEAST_32_BYTES_LONG_12345",
    "DurationInMinutes": 60
  },
  "ApiKeyOptions": {
    "HeaderName": "X-API-KEY-DEV",
    "ApiKeyValue": "DEV_SECRET_API_KEY_VALUE_12345_ABCDE"
  },
  "AdminCredentials": {
    "Username": "admin",
    "Password": "devpassword123"
},
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Debug",
      "Serilog.Sinks.Seq",
      "Serilog.Sinks.OpenTelemetry",
      "Serilog.Enrichers.CorrelationId",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore.Routing": "Information",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Information",
        "System.Net.Http.HttpClient": "Information",
        "BjjWorld.Api": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3} ({SourceContext:l})] {Message:lj}{NewLine}{Exception}",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "Debug",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3} ({SourceContext:l})] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Debug"
        }
        },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "endpoint": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
          "protocol": "HttpProtobuf",
          "restrictedToMinimumLevel": "Information",
          "resourceAttributes": {
            "service.name": "BjjWorld.Api",
            "deployment.environment": "development"
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithCorrelationId",
      "WithMachineName",
      "WithThreadId",
      "WithSpanId",
      "WithTraceId"
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware' and @Level = 'Error'"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "SourceContext = 'Serilog.Sinks.OpenTelemetry.OpenTelemetrySink' and @Level = 'Debug'"
        }
      }
    ],
    "Destructure": [
      {
        "Name": "ToMaximumStringLength",
        "Args": {
          "maximumStringLength": 1000
        }
      },
      {
        "Name": "ToMaximumDepth",
        "Args": {
          "maximumDepth": 10
        }
      }
    ],
    "Properties": {
      "Application": "BjjWorld.Api",
      "ServiceVersion": "1.0.0-dev"
    }
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "${OTEL_EXPORTER_OTLP_ENDPOINT}",
  "OTEL_RESOURCE_ATTRIBUTES": {
    "service.name": "BjjWorld.Api",
    "deployment.environment": "development"
  },
  "SecurityHeaderOptions": {
    "Enable": false,
    "Headers": {
      "XContentTypeOptions": "nosniff",
      "ReferrerPolicy": "no-referrer",
      "XXSSProtection": "1; mode=block",
      "XFrameOptions": "DENY",
      "ContentSecurityPolicy": "block-all-mixed-content; style-src 'self' 'unsafe-inline'; font-src 'self'; form-action 'self'; frame-ancestors 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'",
      "PermissionsPolicy": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()",
      "StrictTransportSecurity": "max-age=31536000"
    }
  }
}

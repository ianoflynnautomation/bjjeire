# BjjEire frontend environment variables.
# Copy to .env.local and fill in values for local dev.
# All variables must be prefixed with VITE_APP_ (stripped at runtime by src/config/env.ts).
# Schema validation: src/config/env.ts — app will throw at boot if required vars are invalid.
# Never commit real .env* files — only this example.

# API base URL — leave as /api to use the Nginx proxy (recommended)
VITE_APP_API_URL=/api

# MSW-based API mocking — enable in dev, never in production
VITE_APP_ENABLE_API_MOCKING=false
VITE_APP_APP_URL=http://localhost:60743
VITE_APP_APP_MOCK_API_PORT=443

# Pagination defaults
VITE_APP_PAGE_SIZE=20
VITE_APP_PAGE_NUMBER=1

# Azure AD / MSAL — public client IDs only, never secrets
VITE_APP_MSAL_CLIENT_ID=
VITE_APP_MSAL_AUTHORITY=https://login.microsoftonline.com/common
VITE_APP_MSAL_API_SCOPE=

# Public contact + social links
VITE_APP_CONTACT_EMAIL=info@bjj-eire.com
VITE_APP_SOCIAL_INSTAGRAM_URL=
VITE_APP_SOCIAL_FACEBOOK_URL=
VITE_APP_GITHUB_URL=

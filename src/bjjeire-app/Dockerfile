FROM node:26-alpine AS build

WORKDIR /app

ENV HUSKY=0

COPY src/bjjeire-app/package.json src/bjjeire-app/package-lock.json ./
RUN npm ci

COPY src/bjjeire-app/ .

ARG NODE_ENV=production
ARG VITE_APP_MSAL_CLIENT_ID
ARG VITE_APP_MSAL_AUTHORITY
ARG VITE_APP_MSAL_API_SCOPE
ARG VITE_APP_CF_BEACON_TOKEN
ARG VITE_APP_APP_URL
ARG VITE_APP_CONTACT_EMAIL=info@bjj-eire.com
ARG VITE_APP_SOCIAL_INSTAGRAM_URL=
ARG VITE_APP_SOCIAL_FACEBOOK_URL=
ARG VITE_APP_GITHUB_URL=
ENV NODE_ENV=${NODE_ENV}
ENV VITE_APP_MSAL_CLIENT_ID=${VITE_APP_MSAL_CLIENT_ID}
ENV VITE_APP_MSAL_AUTHORITY=${VITE_APP_MSAL_AUTHORITY}
ENV VITE_APP_MSAL_API_SCOPE=${VITE_APP_MSAL_API_SCOPE}
ENV VITE_APP_CF_BEACON_TOKEN=${VITE_APP_CF_BEACON_TOKEN}
ENV VITE_APP_APP_URL=${VITE_APP_APP_URL}
ENV VITE_APP_CONTACT_EMAIL=${VITE_APP_CONTACT_EMAIL}
ENV VITE_APP_SOCIAL_INSTAGRAM_URL=${VITE_APP_SOCIAL_INSTAGRAM_URL}
ENV VITE_APP_SOCIAL_FACEBOOK_URL=${VITE_APP_SOCIAL_FACEBOOK_URL}
ENV VITE_APP_GITHUB_URL=${VITE_APP_GITHUB_URL}

RUN npm run build

FROM caddy:2.11.2-alpine
ARG APP_VERSION=dev
LABEL org.opencontainers.image.version="${APP_VERSION}"

COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv

EXPOSE 80

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
